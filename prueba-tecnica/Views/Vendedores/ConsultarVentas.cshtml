@model IEnumerable<PruebaTecnica.data.Models.DTOs.VehiculoVendidoDto>
@{
    ViewData["Title"] = "Ventas por Vendedor";
    var vendedoresDisponibles = ViewBag.Vendedores as IEnumerable<PruebaTecnica.data.Models.Vendedor>;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0"><i class="bi bi-receipt"></i> Consultar Ventas por Vendedor</h2>
    <span class="badge bg-primary-subtle text-primary-emphasis px-3 py-2">Consulta rápida</span>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-dark text-white">Buscar por Cédula</div>
            <div class="card-body">
                <form method="post" class="row g-3">
                    <div class="col-md-8">
                        <input type="text" name="cedula" class="form-control" placeholder="Ingrese la cédula" required />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-dark w-100">
                            <i class="bi bi-search"></i> Consultar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-secondary text-white">Preview de vendedores</div>
            <div class="card-body">
                @if (vendedoresDisponibles != null && vendedoresDisponibles.Any())
                {
                    <div class="list-group list-group-flush small">
                        @foreach (var vendedorDisponible in vendedoresDisponibles.Take(8))
                        {
                            <div class="list-group-item px-0">
                                <div class="fw-semibold">@vendedorDisponible.Cedula</div>
                                <div class="text-muted">@vendedorDisponible.Nombre @vendedorDisponible.Apellido</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No hay vendedores disponibles para mostrar.</p>
                }
            </div>
        </div>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white">
            Vehículos vendidos — Cédula: @ViewBag.Cedula
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Placa</th>
                        <th>Modelo</th>
                        <th>Año</th>
                        <th>Marca</th>
                        <th>Fecha Venta</th>
                        <th>Precio</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Placa</td>
                            <td>@item.Modelo</td>
                            <td>@item.Año</td>
                            <td>@item.Marca</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Precio.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (Model != null && !Model.Any())
{
    <div class="alert alert-warning">No se encontraron ventas para este vendedor.</div>
}