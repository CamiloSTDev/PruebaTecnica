@model IEnumerable<PruebaTecnica.data.Models.DTOs.VehiculoVendidoDto>
@{
    ViewData["Title"] = "Ventas por Vendedor";
}

<h2 class="mb-4"><i class="bi bi-receipt"></i> Consultar Ventas por Vendedor</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-4">
    <div class="card-header bg-dark text-white">Buscar por Cédula</div>
    <div class="card-body">
        <form method="post" class="row g-3">
            <div class="col-md-6">
                <input type="text" name="cedula" class="form-control" placeholder="Ingrese la cédula" required />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-dark w-100">
                    <i class="bi bi-search"></i> Consultar
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="card">
        <div class="card-header bg-dark text-white">
            Vehículos vendidos — Cédula: @ViewBag.Cedula
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Placa</th>
                        <th>Modelo</th>
                        <th>Año</th>
                        <th>Marca</th>
                        <th>Fecha Venta</th>
                        <th>Precio</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Placa</td>
                            <td>@item.Modelo</td>
                            <td>@item.Año</td>
                            <td>@item.Marca</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Precio.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (Model != null && !Model.Any())
{
    <div class="alert alert-warning">No se encontraron ventas para este vendedor.</div>
}