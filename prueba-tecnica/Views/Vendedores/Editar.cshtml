@model PruebaTecnica.data.Models.Vendedor
@{
    ViewData["Title"] = "Actualizar Vendedor";
    var vendedoresDisponibles = ViewBag.Vendedores as IEnumerable<PruebaTecnica.data.Models.Vendedor>;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0"><i class="bi bi-person-gear"></i> Actualizar Vendedor</h2>
    <span class="badge bg-primary-subtle text-primary-emphasis px-3 py-2">Gestión de vendedores</span>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-dark text-white">Buscar Vendedor por Cédula</div>
            <div class="card-body">
                <form asp-action="BuscarParaEditar" method="post" class="row g-3">
                    <div class="col-md-8">
                        <input type="text" name="cedula" class="form-control" placeholder="Ingrese la cédula" required />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-dark w-100">
                            <i class="bi bi-search"></i> Buscar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-secondary text-white">Preview de vendedores</div>
            <div class="card-body">
                @if (vendedoresDisponibles != null && vendedoresDisponibles.Any())
                {
                    <div class="list-group list-group-flush small">
                        @foreach (var vendedorDisponible in vendedoresDisponibles.Take(8))
                        {
                            <div class="list-group-item px-0">
                                <div class="fw-semibold">@vendedorDisponible.Cedula</div>
                                <div class="text-muted">@vendedorDisponible.Nombre @vendedorDisponible.Apellido</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No hay vendedores disponibles para mostrar.</p>
                }
            </div>
        </div>
    </div>
</div>

@if (Model != null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white">Datos del Vendedor</div>
        <div class="card-body">
            <form asp-action="Actualizar" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Cedula" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Cédula</label>
                        <input class="form-control" value="@Model.Cedula" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Apellido</label>
                        <input asp-for="Apellido" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="Email"
                               type="email"
                               class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Guardar Cambios
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}