@model PruebaTecnica.data.Models.Vendedor
@{
    ViewData["Title"] = "Actualizar Vendedor";
}

<h2 class="mb-4"><i class="bi bi-person-gear"></i> Actualizar Vendedor</h2>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-4">
    <div class="card-header bg-dark text-white">Buscar Vendedor por Cédula</div>
    <div class="card-body">
        <form asp-action="BuscarParaEditar" method="post" class="row g-3">
            <div class="col-md-6">
                <input type="text" name="cedula" class="form-control" placeholder="Ingrese la cédula" required />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-dark w-100">
                    <i class="bi bi-search"></i> Buscar
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model != null)
{
    <div class="card">
        <div class="card-header bg-dark text-white">Datos del Vendedor</div>
        <div class="card-body">
            <form asp-action="Actualizar" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Cedula" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Cédula</label>
                        <input class="form-control" value="@Model.Cedula" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Apellido</label>
                        <input asp-for="Apellido" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="Email"
                               type="email"
                               class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Guardar Cambios
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}