@model IEnumerable<PruebaTecnica.data.Models.Venta>
@{
    ViewData["Title"] = "Eliminar Venta";
}

<h2 class="mb-4"><i class="bi bi-trash"></i> Eliminar Venta</h2>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model != null && Model.Any())
{
    <div class="card">
        <div class="card-header bg-dark text-white">Listado de Ventas</div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Vendedor</th>
                        <th>Vehículo</th>
                        <th>Marca</th>
                        <th>Fecha</th>
                        <th>Precio</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var venta in Model)
                    {
                        <tr>
                            <td>@venta.Id</td>
                            <td>@venta.Vendedor.Nombre @venta.Vendedor.Apellido</td>
                            <td>@venta.Vehiculo.Placa — @venta.Vehiculo.Modelo</td>
                            <td>@venta.Vehiculo.Marca.Nombre</td>
                            <td>@venta.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@venta.Precio.ToString("C")</td>
                            <td>
                                <form asp-action="Eliminar" method="post"
                                      onsubmit="return confirm('¿Está seguro que desea eliminar esta venta?')">
                                    <input type="hidden" name="id" value="@venta.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">No hay ventas registradas.</div>
}