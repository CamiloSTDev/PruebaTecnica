<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Prueba Técnica</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="~/">Concesionario</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Vendedores" && currentAction == "Editar" ? "active fw-semibold" : "")" asp-controller="Vendedores" asp-action="Editar">Actualizar Vendedor</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Vendedores" && currentAction == "ConsultarVentas" ? "active fw-semibold" : "")" asp-controller="Vendedores" asp-action="ConsultarVentas">Ventas por Vendedor</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Marcas" && currentAction == "Crear" ? "active fw-semibold" : "")" asp-controller="Marcas" asp-action="Crear">Nueva Marca</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Ventas" && currentAction == "Eliminar" ? "active fw-semibold" : "")" asp-controller="Ventas" asp-action="Eliminar">Eliminar Venta</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <script src="/_framework/aspnetcore-browser-refresh.js"></script>
    }
</body>
</html>