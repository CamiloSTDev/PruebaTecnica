@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center py-5">
    <h1 class="display-5 fw-bold">Sistema de Concesionario</h1>
    <p class="lead text-muted">Selecciona una opción del menú para comenzar</p>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-3">
        <a asp-controller="Vendedores" asp-action="Editar" class="text-decoration-none">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body py-4">
                    <i class="bi bi-person-gear fs-1 text-dark"></i>
                    <h5 class="card-title mt-3">Actualizar Vendedor</h5>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Vendedores" asp-action="ConsultarVentas" class="text-decoration-none">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body py-4">
                    <i class="bi bi-receipt fs-1 text-dark"></i>
                    <h5 class="card-title mt-3">Ventas por Vendedor</h5>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Marcas" asp-action="Crear" class="text-decoration-none">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body py-4">
                    <i class="bi bi-tag fs-1 text-dark"></i>
                    <h5 class="card-title mt-3">Nueva Marca</h5>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Ventas" asp-action="Eliminar" class="text-decoration-none">
            <div class="card text-center h-100 shadow-sm">
                <div class="card-body py-4">
                    <i class="bi bi-trash fs-1 text-dark"></i>
                    <h5 class="card-title mt-3">Eliminar Venta</h5>
                </div>
            </div>
        </a>
    </div>
</div>